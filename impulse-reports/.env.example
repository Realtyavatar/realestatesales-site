# Supabase — from your project's Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Resend (https://resend.com) — used to email PDF reports to clients.
# Optional: without it, "Email report" is disabled but download still works.
RESEND_API_KEY=
# The verified sender address in Resend, e.g. reports@impulseelectrical.com.au
REPORT_FROM_EMAIL=
